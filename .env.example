# Database
# For Docker (Standard/Secure): file:/app/prisma/data/dev.db
# For Manual Host: file:./dev.db
DATABASE_URL="file:/app/prisma/data/dev.db"

# Authentication
# MANDATORY: Change JWT_SECRET to a random secure string for production
JWT_SECRET="change-me-to-a-secure-random-string"
SESSION_DURATION_SECONDS=3600

# Environment
NODE_ENV=production
PORT=3000
HOSTNAME="0.0.0.0"

# SSO (Optional - OpenID Connect)
# NEXT_PUBLIC_BASE_URL=https://your-app-url.gov
# SSO_ISSUER_URL=https://idp.agency.gov
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
