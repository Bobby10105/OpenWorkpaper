generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  password           String?
  role               String
  mustChangePassword Boolean  @default(false)
  ssoProvider        String?
  ssoId              String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  teamMembers        TeamMember[]
}

model Audit {
  id                      String       @id @default(uuid())
  title                   String
  description             String?
  category                String?
  auditNumber             String?
  objective               String?
  status                  String       @default("In Progress")
  fieldworkStartDate      DateTime?
  fieldworkEndDate        DateTime?
  reportIssuedDate        DateTime?
  milestoneAttachmentUrl   String?
  milestoneAttachmentName  String?
  pbcAttachmentUrl         String?
  pbcAttachmentName        String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  procedures              Procedure[]
  procedureGroups         ProcedureGroup[]
  teamMembers             TeamMember[]
}

model TeamMember {
  id        String   @id @default(uuid())
  auditId   String
  userId    String?
  name      String
  role      String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  audit              Audit       @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user               User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedProcedures Procedure[] @relation("ProcedureAssignment")
}

model Procedure {
  id           String       @id @default(uuid())
  auditId      String
  groupId      String?
  phase        String
  title        String?
  purpose      String?
  source       String?
  scope        String?
  methodology  String?
  results      String?
  conclusions  String?
  preparedBy   String?
  preparedDate DateTime?
  reviewedBy   String?
  reviewedDate DateTime?
  assignedToId String?
  displayOrder Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  attachments  Attachment[]
  messages     ProcedureMessage[]
  audit        Audit        @relation(fields: [auditId], references: [id], onDelete: Cascade)
  group        ProcedureGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignedTo   TeamMember? @relation("ProcedureAssignment", fields: [assignedToId], references: [id], onDelete: SetNull)
}

model ProcedureGroup {
  id           String      @id @default(uuid())
  auditId      String
  phase        String      // Planning, Fieldwork, Reporting
  title        String
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  audit        Audit       @relation(fields: [auditId], references: [id], onDelete: Cascade)
  procedures   Procedure[]
}

model ProcedureMessage {
  id          String    @id @default(uuid())
  procedureId String
  text        String
  author      String
  createdAt   DateTime  @default(now())
  
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
}

model Attachment {
  id            String    @id @default(uuid())
  procedureId   String
  filename      String
  filepath      String
  mimetype      String?
  size          Int?
  displayOrder  Int?
  preparedBy    String?
  preparedDate  DateTime?
  reviewedBy    String?
  reviewedDate  DateTime?
  createdAt     DateTime  @default(now())

  procedure     Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
}

model AuditTemplate {
  id          String              @id @default(uuid())
  name        String              @unique
  description String?
  groups      TemplateGroup[]
  procedures  TemplateProcedure[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model TemplateGroup {
  id           String              @id @default(uuid())
  templateId   String
  phase        String              // Planning, Fieldwork, Reporting
  title        String
  displayOrder Int                 @default(0)
  procedures   TemplateProcedure[]
  
  template     AuditTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model TemplateProcedure {
  id           String        @id @default(uuid())
  templateId   String
  groupId      String?
  phase        String        // Planning, Fieldwork, Reporting
  title        String
  purpose      String?
  displayOrder Int          @default(0)
  
  template     AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  group        TemplateGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  details     String
  performedBy String?
  timestamp   DateTime @default(now())
}
